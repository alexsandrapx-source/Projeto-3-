## Código Parte 2.1 — Controle de Servo com Potenciômetro

```cpp
#include <Arduino.h>
#include <ESP32Servo.h>

const uint8_t pinoServo = 18;
const uint8_t pinoPot = 34;

Servo servoMotor;

int leituraADC;
int angulo;

void setup() {

  Serial.begin(115200);

  servoMotor.attach(pinoServo);

}

void loop() {

  leituraADC = analogRead(pinoPot);

  angulo = map(leituraADC, 0, 4095, 0, 180);

  servoMotor.write(angulo);

  Serial.print("ADC: ");
  Serial.print(leituraADC);

  Serial.print("   Angulo: ");
  Serial.println(angulo);

  delay(50);

}
```
